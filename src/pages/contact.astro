---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';

// Contact methods
const contactMethods = [
  {
    icon: 'discord',
    title: 'Discord',
    description: 'サーバーに参加して、部員と直接お話しできます',
    href: 'https://discord.gg/7tebKugCWp',
    buttonText: 'Discordに参加',
    color: 'from-[#5865F2] to-[#7289DA]'
  },
  {
    icon: 'twitter',
    title: 'X (Twitter)',
    description: 'DMでお気軽にお問い合わせください',
    href: 'https://twitter.com/messages/compose?recipient_id=1508526577549975552',
    buttonText: 'DMを送る',
    color: 'from-[#1DA1F2] to-[#0D8BD9]'
  }
];

// FAQs
const faqs = [
  {
    question: '入部に必要な条件はありますか？',
    answer: '特別な条件はありません。プログラミングに興味があれば、初心者でも大歓迎です。学年も問いません。'
  },
  {
    question: 'プログラミング未経験でも大丈夫ですか？',
    answer: 'はい、まったく問題ありません。4月には1年生向けのC言語講習会も開催しています。先輩が優しくサポートします。'
  },
  {
    question: '兼部はできますか？',
    answer: 'はい、兼部は可能です。多くの部員が他の部活動と両立しています。'
  },
  {
    question: 'パソコンを持っていないのですが...',
    answer: 'プロ研が所有しているパソコンを利用できますので、心配ありません。もちろん、自分のノートパソコンを持参しても構いません。'
  },
  {
    question: '年会費は何に使われますか？',
    answer: '年会費1,000円は、必要な機材の購入や校外での活動費用（交通費など）に使用されます。'
  },
  {
    question: '見学だけでもいいですか？',
    answer: 'もちろんです！放課後の活動時間中であれば、いつでも見学に来ていただけます。まずは雰囲気を見てください。'
  }
];
---

<BaseLayout title="入部案内 | NITKPC">
  <!-- Page Header -->
  <section class="pt-32 pb-16 bg-gradient-radial">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        <span class="gradient-text">入部案内</span>
      </h1>
      <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        プログラミング研究部は、あなたの入部をいつでも歓迎しています
      </p>
    </div>
  </section>
  
  <!-- Welcome Message -->
  <section class="section">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <div class="w-24 h-24 mx-auto mb-8 rounded-3xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-white text-4xl font-bold animate-float">
          👋
        </div>
        <h2 class="text-3xl font-bold mb-6">お気軽にご相談ください</h2>
        <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed">
          プログラミング研究部は、あなたの入部をいつでも歓迎しております。もちろん、兼部していただいても構いません。
          入部しようか迷っている方のために、DiscordのサーバーやTwitterのDMも解放しておりますので、ぜひ気軽にご相談ください。
          私たちは、あなたと共に学べる日を楽しみにしています。
        </p>
      </div>
    </div>
  </section>
  
  <!-- Contact Methods -->
  <section class="section bg-[var(--color-bg-secondary)]">
    <div class="container mx-auto px-4">
      <SectionTitle 
        title="お問い合わせ方法"
        subtitle="お好きな方法でお気軽にご連絡ください"
      />
      
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {contactMethods.map((method) => (
          <div class="card text-center">
            <div class:list={["w-16 h-16 mx-auto mb-4 rounded-2xl bg-gradient-to-br flex items-center justify-center", method.color]}>
              {method.icon === 'discord' && (
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
                </svg>
              )}
              {method.icon === 'twitter' && (
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold mb-2">{method.title}</h3>
            <p class="text-[var(--color-text-secondary)] mb-6">{method.description}</p>
            <a href={method.href} target="_blank" rel="noopener noreferrer" class="btn-primary w-full justify-center">
              {method.buttonText}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- FAQ -->
  <section class="section">
    <div class="container mx-auto px-4">
      <SectionTitle 
        title="よくある質問"
        subtitle="入部に関するよくある質問にお答えします"
      />
      
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq, index) => (
          <details class="card group" open={index === 0}>
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <span class="font-bold pr-4">{faq.question}</span>
              <svg class="w-5 h-5 shrink-0 text-primary-500 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-[var(--color-text-secondary)] leading-relaxed">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Location -->
  <section class="section bg-[var(--color-bg-secondary)]">
    <div class="container mx-auto px-4">
      <SectionTitle 
        title="活動場所"
        subtitle="見学はいつでも歓迎です"
      />
      
      <div class="max-w-3xl mx-auto">
        <div class="card">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-primary-500/20 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg mb-2">釧路工業高等専門学校</h3>
              <p class="text-[var(--color-text-secondary)] mb-2">
                情報棟2F マルチワークラボラトリ
              </p>
              <p class="text-sm text-[var(--color-text-secondary)]">
                活動時間: 月〜金 16:40 - 18:00（祝日を除く）
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

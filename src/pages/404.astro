---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - ページが見つかりません | NITKPC">
  <section class="min-h-[70vh] flex items-center justify-center">
    <div class="container mx-auto px-4 text-center">
      <div class="max-w-lg mx-auto">
        <!-- 404 Graphic -->
        <div class="mb-8">
          <div class="text-9xl font-bold gradient-text">404</div>
        </div>
        
        <h1 class="text-3xl font-bold mb-4">ページが見つかりません</h1>
        
        <p class="text-lg text-[var(--color-text-secondary)] mb-8">
          お探しのページは存在しないか、移動した可能性があります。
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/" class="btn-primary">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            ホームに戻る
          </a>
          <a href="/contact" class="btn-secondary">
            お問い合わせ
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

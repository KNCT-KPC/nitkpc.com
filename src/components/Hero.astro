---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  title,
  subtitle,
  ctaText = "入部",
  ctaHref = "/contact",
  secondaryCtaText = "もっと知る",
  secondaryCtaHref = "/about",
} = Astro.props;
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-radial"></div>

  <!-- Animated Background Elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div
      class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl animate-float"
    >
    </div>
    <div
      class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent-500/20 rounded-full blur-3xl animate-float"
      style="animation-delay: 1s;"
    >
    </div>
  </div>

  <!-- Grid Pattern -->
  <div
    class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:50px_50px]"
  >
  </div>

  <!-- Content -->
  <div class="relative z-10 container mx-auto px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <!-- Badge -->
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-8 animate-fade-in"
      >
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        <span class="text-sm font-medium text-[var(--color-text-secondary)]">
          新しい仲間を募集中
        </span>
      </div>

      <!-- Title -->
      <h1
        class="text-4xl md:text-5xl lg:text-7xl font-bold mb-6 animate-slide-up"
      >
        <span class="gradient-text">{title}</span>
      </h1>

      <!-- Subtitle -->
      {
        subtitle && (
          <p
            class="text-lg md:text-xl text-[var(--color-text-secondary)] mb-10 max-w-2xl mx-auto animate-slide-up"
            style="animation-delay: 0.1s;"
          >
            {subtitle}
          </p>
        )
      }

      <!-- CTAs -->
      <div
        class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up"
        style="animation-delay: 0.2s;"
      >
        <a href={ctaHref} class="btn-primary">
          {ctaText}
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a href={secondaryCtaHref} class="btn-secondary">
          {secondaryCtaText}
        </a>
      </div>

      <!-- Stats -->
      <div
        class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-6 animate-fade-in"
        style="animation-delay: 0.4s;"
      >
        <div class="glass rounded-2xl p-6">
          <div class="text-3xl font-bold gradient-text mb-1">52+</div>
          <div class="text-sm text-[var(--color-text-secondary)]">部員数</div>
        </div>
        <div class="glass rounded-2xl p-6">
          <div class="text-3xl font-bold gradient-text mb-1">5日</div>
          <div class="text-sm text-[var(--color-text-secondary)]">週間活動</div>
        </div>
        <div class="glass rounded-2xl p-6">
          <div class="text-3xl font-bold gradient-text mb-1">∞</div>
          <div class="text-sm text-[var(--color-text-secondary)]">
            学べる技術
          </div>
        </div>
        <div class="glass rounded-2xl p-6">
          <div class="text-3xl font-bold gradient-text mb-1">1000円</div>
          <div class="text-sm text-[var(--color-text-secondary)]">
            年会費のみ
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg
      class="w-6 h-6 text-[var(--color-text-secondary)]"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

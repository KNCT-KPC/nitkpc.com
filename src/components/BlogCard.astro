---
interface Props {
  title: string;
  description: string;
  author: string;
  pubDate: Date;
  href: string;
  image?: string;
  tags?: string[];
}

const { title, description, author, pubDate, href, image, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<a href={href} class="card block group overflow-hidden">
  <!-- Image -->
  {image ? (
    <div class="relative h-48 -mx-6 -mt-6 mb-4 overflow-hidden">
      <img 
        src={image} 
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-card)] to-transparent"></div>
    </div>
  ) : (
    <div class="relative h-48 -mx-6 -mt-6 mb-4 bg-gradient-to-br from-primary-500/20 to-accent-500/20 flex items-center justify-center">
      <svg class="w-16 h-16 text-primary-500/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
      </svg>
    </div>
  )}
  
  <!-- Tags -->
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-3">
      {tags.slice(0, 3).map((tag) => (
        <span class="px-2 py-0.5 text-xs font-medium bg-primary-500/10 text-primary-500 rounded-full">
          #{tag}
        </span>
      ))}
    </div>
  )}
  
  <!-- Title -->
  <h3 class="text-lg font-bold mb-2 group-hover:text-primary-500 transition-colors line-clamp-2">
    {title}
  </h3>
  
  <!-- Description -->
  <p class="text-sm text-[var(--color-text-secondary)] mb-4 line-clamp-2">
    {description}
  </p>
  
  <!-- Meta -->
  <div class="flex items-center justify-between text-sm text-[var(--color-text-secondary)]">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      {author}
    </span>
    <span>{formattedDate}</span>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

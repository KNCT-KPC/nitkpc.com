---
interface Props {
  title: string;
  description?: string;
  href?: string;
  icon?: string;
  variant?: 'default' | 'glass';
}

const { 
  title, 
  description, 
  href, 
  icon,
  variant = 'default'
} = Astro.props;

const Tag = href ? 'a' : 'div';
const baseClass = variant === 'glass' ? 'glass rounded-2xl p-6' : 'card';
---

<Tag 
  href={href}
  class:list={[
    baseClass,
    "block group",
    { "cursor-pointer": href }
  ]}
>
  {icon && (
    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary-500/20 to-accent-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
      <span class="text-2xl">{icon}</span>
    </div>
  )}
  
  <h3 class="text-xl font-bold mb-2 group-hover:text-primary-500 transition-colors">
    {title}
  </h3>
  
  {description && (
    <p class="text-[var(--color-text-secondary)]">
      {description}
    </p>
  )}
  
  {href && (
    <div class="mt-4 flex items-center gap-2 text-primary-500 font-medium opacity-0 group-hover:opacity-100 transition-opacity">
      <span>詳しく見る</span>
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  )}
  
  <slot />
</Tag>
